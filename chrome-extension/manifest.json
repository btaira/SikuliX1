{
  "manifest_version": 3,
  "name": "SikuliX for Chrome",
  "version": "1.0.0",
  "description": "Visual browser automation using image recognition — a SikuliX-like tool for Chrome.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "debugger"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open SikuliX Panel",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["capture.html", "capture.js", "matcher.worker.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
